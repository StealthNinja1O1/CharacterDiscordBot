# LLM API Configuration
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.7

# Discord Bot Configuration
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID= # comma separated list of channel IDs where the bot is allowed to respond, leave empty for all channels
DISCORD_ALLOWED_USERS=1402920090344755323,1234567890

# Bot Behavior Settings
RANDOM_RESPONSE_RATE=1 # Set to -1 to disable random responses
MAX_HISTORY_MESSAGES=30
MAX_CONTEXT_TOKENS=20000
IGNORE_OTHER_BOTS=true
TRIGGER_KEYWORDS=assistant,bot,helper,chatgpt
ADD_TIMESTAMPS=true # Add timestamps to messages
MIN_RESPONSE_INTERVAL_SECONDS=0
REPLY_TO_MENTIONS=true
MENTION_TRIGGER_ALLOWED_USERS=1402920090344755323,1234567890
ADD_NOTHINK=true
ENABLE_VISION=false # Enable image vision support for multimodal models
ENABLE_USER_STATUS=true # Enable user status (online, offline, etc.) in the context
ALLOW_RENAMING=false # Allow the bot to change nicknames

# Lorebook
ALLOW_LOREBOOK_EDITING=false
# Character File Path
CHARACTER_FILE_PATH=./character.json
