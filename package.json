{
  "name": "v2character-discord-bot",
  "version": "1.0.0",
  "description": "A Discord bot that behaves like a character defined in character.json",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun src/index.ts",
    "start:node": "npx tsx src/index.ts",
    "dev": "bun --watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "discord",
    "bot",
    "ai",
    "character"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "bun": ">=1.1"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "gpt-tokenizer": "^3.2.0",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^20.10.5",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3"
  }
}
